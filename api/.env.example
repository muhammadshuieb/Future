# اسم القاعدة ثابت: radius (نفس radius.sql: Database: radius)
DATABASE_URL=mysql://root:muhammadshuieb@mysql:3306/radius
REDIS_URL=redis://redis:6379
JWT_SECRET=change-me-to-a-long-random-string
AES_SECRET_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# CORS_ORIGINS is required when NODE_ENV=production (comma-separated origins).
# CORS_ORIGINS=https://your-panel.example.com,http://localhost:8080
# After importing radius.sql, rm_managers root password is from the dump (not the project default).
# One-time reset on next API boot: RM_ROOT_PASSWORD_RESET=1 (then remove). Optional plaintext:
# RM_BOOTSTRAP_ROOT_PLAINTEXT=your-new-root-password
# RM_ROOT_PASSWORD_RESET=1
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
COA_TIMEOUT_MS=3000
PORT=3000
# Google Drive backup (OAuth “Connect” button). Create a “Web application” OAuth client in Google Cloud Console
# and add redirect URI: {PUBLIC_APP_URL}/api/maintenance/rclone/google/callback
# PUBLIC_APP_URL=http://localhost:3000
# PUBLIC_FRONTEND_URL=http://localhost:8080
# إن وُجد reverse proxy يمرّر X-Forwarded-Host / X-Forwarded-Proto يمكن للـ API استنتاج عنوان الـ API وReferer للواجهة دون هذين المتغيرين في كثير من الحالات.
# GOOGLE_BACKUP_CLIENT_ID=
# GOOGLE_BACKUP_CLIENT_SECRET=
# APP_TIMEZONE=Asia/Damascus
# DMA_MODE=true  # Radius Manager–only: skip sql/migrations, no usage sync jobs, dashboard reads rm_*/rad*/nas; restore = raw SQL import only
# UPDATE_USAGE_EVERY_MS=60000           # BullMQ interval for update-usage job
# USAGE_CACHE_REFRESH_EVERY_CYCLES=5    # Rebuild user_usage_live every N cycles (reduces CPU on large radacct)
# ACTIVE_SESSION_FRESH_HOURS=72         # Ignore stale "open" sessions with very old acctupdatetime/acctstarttime
# Self-update (admin-only maintenance updates page)
# APP_UPDATE_ENABLED=false
# APP_UPDATE_TOKEN=change-this-long-random-token
# APP_UPDATE_REMOTE=origin
# APP_UPDATE_BRANCH=main
# APP_UPDATE_REPO_DIR=/app
# APP_UPDATE_DOCKER_ENABLED=true
# APP_UPDATE_COMPOSE_DIR=/app
# APP_UPDATE_COMPOSE_FILE=
# APP_UPDATE_GIT_BIN=git
# APP_UPDATE_COMPOSE_BIN=docker
# إن فشل التحديث بتعارض منافذ (3306 / 3001): أوقف الحاوية أو الخدمة التي تحجز المنفذ على المضيف، أو غيّر تعيين المنافذ في override.
# If docker compose fails with "port is already allocated", stop the conflicting container/host service or change host port mappings.
# APP_UPDATE_COMPOSE_REMOVE_ORPHANS=true   # append --remove-orphans to compose up (default true)
# عند تعارض منافذ 3306/3001: إعادة المحاولة بعد إزالة حاويات mysql,waha ضمن نفس مشروع Compose (volumes لا تُحذف).
# APP_UPDATE_COMPOSE_RETRY_RECYCLE_ON_PORT_CONFLICT=true   # default true
# APP_UPDATE_COMPOSE_RECYCLE_SERVICES=mysql,waha
# إذا ظهرت حاويات بأسماء future-radius_mysql_1 ثم تعارض منافذ، ثبّت اسم المشروع كما في الاسم قبل الشرطة الأولى:
# APP_UPDATE_COMPOSE_PROJECT_NAME=future-radius
# APP_UPDATE_COMPOSE_RECYCLE_MAX_PASSES=2   # عدد دورات recycle قبل الإعلان عن الفشل (افتراضي 2)
# APP_UPDATE_COMPOSE_KILL_BEFORE_RECYCLE=false   # إن true يُرسل kill قبل الإزالة في كل دورة recycle
