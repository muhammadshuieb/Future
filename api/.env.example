DATABASE_URL=mysql://root:change-me@mysql:3306/future_radius
# Use utf8mb4 server-wide and for schema/tables. The API pool uses charset=utf8mb4 and runs SET NAMES utf8mb4 COLLATE utf8mb4_unicode_ci on each connection.
# Staff panel JWT login (`/api/auth/login`):
# - Table `users` (bcrypt): bootstraps `STAFF_BOOTSTRAP_EMAIL` when tenants row exists.
# - Table `legacy_managers` (bcrypt): same email/password; managername = local-part (e.g. root@… -> root). Legacy MD5 rows upgrade on first successful login or API boot if plaintext matches LEGACY_BOOTSTRAP_ROOT_PLAINTEXT.
# First staff user (`users`): set for Docker/production (NODE_ENV=production). Example default for new projects:
# STAFF_BOOTSTRAP_PASSWORD=muhammadshuieb
# Set once to re-hash bcrypt after password changes: STAFF_BOOTSTRAP_PASSWORD_RESET=1 then restart API.
# STAFF_BOOTSTRAP_EMAIL=root@futureradius.local
# LEGACY_BOOTSTRAP_ROOT_PLAINTEXT=muhammadshuieb
# STAFF_BOOTSTRAP_PASSWORD_RESET=0
REDIS_URL=redis://redis:6379
JWT_SECRET=change-me-to-a-long-random-string
AES_SECRET_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
RADIUS_SECRET_DEFAULT=change-me
RADIUS_DB_USER=radius
RADIUS_DB_PASSWORD=change-me
COA_TIMEOUT_MS=3000
PORT=3000
WAHA_URL=http://waha:3000
WAHA_INTERNAL_URL=http://waha:3000
WAHA_SESSION_NAME=default
WAHA_API_KEY=future-radius-waha-key
PROMETHEUS_URL=http://prometheus:9090
ALERTMANAGER_URL=http://alertmanager:9093
GRAFANA_PUBLIC_URL=http://localhost:3300
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173
PUBLIC_APP_URL=http://localhost:8080
PUBLIC_FRONTEND_URL=http://localhost:8080
APP_TIMEZONE=Asia/Riyadh

# In-app updates (when APP_UPDATE_ENABLED=true on the host .env)
APP_UPDATE_COMPOSE_PROJECT_NAME=future
APP_UPDATE_COMPOSE_BIN=docker
APP_UPDATE_COMPOSE_UP_SERVICES=api,worker,web
