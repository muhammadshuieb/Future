MYSQL_ROOT_PASSWORD=change-me
MYSQL_DATABASE=future_radius
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=change-me

RADIUS_DB_USER=radius
RADIUS_DB_PASSWORD=change-me
RADIUS_SECRET_DEFAULT=change-me

DATABASE_URL=mysql://root:change-me@mysql:3306/future_radius
REDIS_URL=redis://redis:6379
JWT_SECRET=change-me-to-a-long-random-string
AES_SECRET_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Staff panel (`/api/auth/login`): required when the API runs with NODE_ENV=production (Dockerfile).
# Without this, bootstrap skips creating `users` and the table stays empty → invalid_credentials.
STAFF_BOOTSTRAP_EMAIL=admin@futureradius.local
STAFF_BOOTSTRAP_PASSWORD=muhammadshuieb

WAHA_API_KEY=future-radius-waha-key
WAHA_URL=http://waha:3000
WAHA_INTERNAL_URL=http://waha:3000
WAHA_SESSION_NAME=default
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=change-me
WHATSAPP_SWAGGER_USERNAME=admin
WHATSAPP_SWAGGER_PASSWORD=change-me
WHATSAPP_DEFAULT_COUNTRY_CODE=963

PROMETHEUS_URL=http://prometheus:9090
ALERTMANAGER_URL=http://alertmanager:9093
GRAFANA_PUBLIC_URL=http://localhost:3300
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me

CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173
# Same origin as the staff UI (`web` nginx serves `/` and proxies `/api`, `/ws` to `api:3000`).
PUBLIC_APP_URL=http://localhost:8080
PUBLIC_FRONTEND_URL=http://localhost:8080
APP_TIMEZONE=Asia/Riyadh
FREERADIUS_DEBUG=0
# Retention for scheduled backups written by the API/worker under BACKUP_DIR (see docker-compose).
BACKUP_RETENTION_DAYS=14
