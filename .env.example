# Copy this file to `.env` and set strong unique values before deploy.

# Database
# Keep these defaults only for first local boot, then rotate in production.
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=radius
RADIUS_DB_USER=radius
RADIUS_DB_PASSWORD=radius123

# API security
JWT_SECRET=change-me-in-production
# 64 hex chars (32 bytes) default for first boot. Rotate in production.
AES_SECRET_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# WAHA
WAHA_API_KEY=future-radius-waha-key
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=future-radius-dashboard-pass
WHATSAPP_SWAGGER_USERNAME=admin
WHATSAPP_SWAGGER_PASSWORD=future-radius-dashboard-pass

# Optional
WAHA_INTERNAL_URL=http://waha:3000
WAHA_SESSION_NAME=default
FREERADIUS_DEBUG=0

# Default admin bootstrap (created on first API start if missing)
SEED_ADMIN_EMAIL=admin@local.test
SEED_ADMIN_NAME=admin
SEED_ADMIN_PASSWORD=muhammadshuieb
