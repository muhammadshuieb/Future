# Copy this file to `.env` and set strong unique values before deploy.

# Database
# Keep these defaults only for first local boot, then rotate in production.
# phpMyAdmin login: use MySQL user `root` + MYSQL_ROOT_PASSWORD, or `radius` + RADIUS_DB_PASSWORD.
# If you change passwords here after MySQL already initialized, the old passwords stay in the volume
# until you reset the DB user or remove the mysql_data volume (data loss).
MYSQL_ROOT_PASSWORD=muhammadshuieb
MYSQL_DATABASE=radius
RADIUS_DB_USER=radius
# Used by api, freeradius, and MySQL first-init (z-futureradius-followup.sh) — keep one value.
RADIUS_DB_PASSWORD=muhammadshuieb

# API security
JWT_SECRET=change-me-in-production
# In production set NODE_ENV=production (API will refuse default JWT).
# NODE_ENV=production
# CORS: comma-separated origins. In production this must be explicitly set.
# CORS_ORIGINS=https://your-panel.example.com,http://localhost:8080
# Alias for the same list:
# ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173
# CoA (UDP disconnect to NAS)
# COA_TIMEOUT_MS=3000
# COA_RETRY_COUNT=3
# COA_RETRY_DELAY_MS=2000
# After UDP CoA fails all retries, try MikroTik REST kick if NAS API creds exist (1=yes, 0=no)
# COA_MIKROTIK_FALLBACK=1

# MySQL pool (api + lib/db.ts). Tune under load; stay below MySQL max_connections.
# MYSQL_POOL_CONNECTION_LIMIT=32
# MYSQL_POOL_QUEUE_LIMIT=0

# Staff JWT lifetime (jsonwebtoken `expiresIn`, e.g. 12h, 7d)
# JWT_EXPIRES_IN=7d

# Split workers: set to 1 on main `worker` and run `docker compose --profile split-workers up -d worker-usage`
# SKIP_BULLMQ_UPDATE_USAGE=0
# Worker: poll RouterOS API (NAS rows with apiusername + IPv4 nasname). Minimum 60000 ms.
# MIKROTIK_API_SYNC_MS=300000
# MikroTik REST fallback (enable API on router; set nas_servers.mikrotik_api_*)
# MIKROTIK_REST_TLS=0
# MIKROTIK_REST_PORT=80
# MIKROTIK_TLS_INSECURE=0
# LOGIN_RATE_LIMIT_MAX=40
# 64 hex chars (32 bytes) default for first boot. Rotate in production.
AES_SECRET_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# WAHA
WAHA_API_KEY=future-radius-waha-key
WAHA_DASHBOARD_USERNAME=root
WAHA_DASHBOARD_PASSWORD=muhammadshuieb
WHATSAPP_SWAGGER_USERNAME=root
WHATSAPP_SWAGGER_PASSWORD=muhammadshuieb

# Radius Manager / DMA: لو استوردت radius.sql فكلمة مرور root هي من النسخة القديمة وليست افتراض المشروع.
# لتعيين كلمة مرور root مرة واحدة ثم إعادة التشغيل: RM_ROOT_PASSWORD_RESET=1 (ثم احذف السطر من .env).
# RM_BOOTSTRAP_ROOT_PLAINTEXT=your-new-root-password
# RM_ROOT_PASSWORD_RESET=1

# Optional
WAHA_INTERNAL_URL=http://waha:3000
WAHA_SESSION_NAME=default
# 1 = freeradius -X (verbose). RADIUS NAS clients: UI "IP" = packet source IP (e.g. MikroTik WireGuard peer 10.20.0.2), not the server IP — see install method §11.
FREERADIUS_DEBUG=0

# Google Drive backup (optional): OAuth client + public URLs for “Connect Google” in Maintenance
# PUBLIC_APP_URL=http://localhost:3000
# PUBLIC_FRONTEND_URL=http://localhost:8080
# GOOGLE_BACKUP_CLIENT_ID=
# GOOGLE_BACKUP_CLIENT_SECRET=
# APP_TIMEZONE=Asia/Damascus
# Self-update (used by /api/maintenance/updates)
# APP_UPDATE_ENABLED=false
# APP_UPDATE_TOKEN=change-this-long-random-token
# APP_UPDATE_REMOTE=origin
# APP_UPDATE_BRANCH=main
# APP_UPDATE_REPO_DIR=/app
# APP_UPDATE_DOCKER_ENABLED=true
# APP_UPDATE_COMPOSE_DIR=/app
# APP_UPDATE_COMPOSE_FILE=
# APP_UPDATE_GIT_BIN=git
# APP_UPDATE_COMPOSE_BIN=docker
