# Copy this file to `.env` and set strong unique values before deploy.

# Database
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_MYSQL_ROOT_PASSWORD
MYSQL_DATABASE=radius
RADIUS_DB_USER=radius
RADIUS_DB_PASSWORD=CHANGE_ME_STRONG_RADIUS_DB_PASSWORD

# API security
JWT_SECRET=CHANGE_ME_STRONG_JWT_SECRET_MIN_32_CHARS
# 64 hex chars (32 bytes). Example: `openssl rand -hex 32`
AES_SECRET_KEY=CHANGE_ME_64_HEX_AES_SECRET_KEY

# WAHA
WAHA_API_KEY=CHANGE_ME_STRONG_WAHA_API_KEY
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=CHANGE_ME_STRONG_WAHA_DASHBOARD_PASSWORD
WHATSAPP_SWAGGER_USERNAME=admin
WHATSAPP_SWAGGER_PASSWORD=CHANGE_ME_STRONG_WAHA_SWAGGER_PASSWORD

# Optional
WAHA_INTERNAL_URL=http://waha:3000
FREERADIUS_DEBUG=0

# Default admin bootstrap (created on first API start if missing)
SEED_ADMIN_EMAIL=admin@local.test
SEED_ADMIN_NAME=admin
SEED_ADMIN_PASSWORD=muhammadshuieb
